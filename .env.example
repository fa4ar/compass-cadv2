# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_ACCESS_SECRET="your-super-secret-access-key-min-32-characters-long"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-characters-long"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS=10

# ============================================
# FRONTEND / BACKEND URLs
# ============================================
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"
NEXT_PUBLIC_FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_RADIO_SOCKET_URL="http://localhost:3002"
NEXT_PUBLIC_RADIO_AUTH_TOKEN="radio"
NEXT_PUBLIC_RADIO_DISPATCH_NAC_ID="141"

# ============================================
# SERVER PORT
# ============================================
PORT=4000

# ============================================
# DISCORD OAUTH & BOT
# ============================================
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_REDIRECT_URI="http://localhost:4000/api/auth/discord/callback"
DISCORD_GUILD_ID=""
DISCORD_BOT_TOKEN=""

# Role Mapping (format: {"role":"discord_role_id"})
DISCORD_ROLE_MAPPING={"admin":"","dispatcher":"","citizen":"","police":"","ems":"","fire":"","supervisor":""}

# ============================================
# BETA TEST
# ============================================
BETA_TEST_ROLE_ID=""